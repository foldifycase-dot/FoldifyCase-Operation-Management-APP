}
.lf-field input:focus { border-color:var(--gold); }
.lf-field input::placeholder { color:var(--t4); }
.lf-actions { display:flex; gap:8px; align-items:center; margin-top:13px; }
.btn-add {
  padding:8px 20px; background:var(--gold);
  color:var(--ink); border:none; border-radius:var(--r-s);
  font-family:var(--dis); font-weight:700;
  font-size:12px; letter-spacing:0.07em;
