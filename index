<script>
/* ══════════════════════════════════════════
   CONFIG
══════════════════════════════════════════ */
const PROXY      = 'https://foldify-case-operation-management-a.vercel.app/api/proxy';
const UNIT_COST  = 12.50; // default cost per unit — update to match your products
const SHIP_RATE  = 0.045; // shipping as % of revenue — update to match your rates

/* ══════════════════════════════════════════
   STATE
══════════════════════════════════════════ */
let rows         = [];          // live data merged from Shopify + ad platforms
let activeRange  = '7d';
let activeMkt    = 'all';
let isLiveData   = false;

// Ad platform live totals (populated after sync)
let livePlatforms = {
  meta:   null,  // { spend, revenue, roas, cpa, conversions } — connected ✅
  google: null,  // waiting for API approval ⏳
  ms:     null,  // skipped for now ⏳
};

/* ══════════════════════════════════════════
   DATE HELPERS
══════════════════════════════════════════ */
function getRange(key) {
  const now   = new Date();
  const today = now.toISOString().slice(0,10);
  const map   = { today:0, '7d':6, '30d':29, '90d':89,
    ytd: Math.floor((now - new Date(now.getFullYear(),0,1)) / 86400000) };
  const days  = map[key] ?? 6;
  const from  = new Date(now - days*86400000).toISOString().slice(0,10);
  return { from, to: today };
}

/* ══════════════════════════════════════════
   MAIN SYNC — fetch all live data
══════════════════════════════════════════ */
async function doSync() {
  const btn = document.getElementById('syncBtn');
  btn.textContent = '⟳ Syncing...';
  btn.style.opacity = '0.7';
  btn.disabled = true;

  const { from, to } = getRange(activeRange);
  toast('Fetching live data from Shopify + Meta...', 'ok');

  try {
    // Fetch Shopify + Meta in parallel
    // Google + Microsoft will be added once API keys are in Vercel
    const [shopifyRes, metaRes] = await Promise.allSettled([
      fetch(`${PROXY}?service=shopify&action=daily-sales&from=${from}&to=${to}`),
      fetch(`${PROXY}?service=meta-ads&from=${from}&to=${to}`),
      // Google: uncomment when approved
      // fetch(`${PROXY}?service=google-ads&from=${from}&to=${to}`),
      // Microsoft: uncomment when ready
      // fetch(`${PROXY}?service=ms-ads&from=${from}&to=${to}`),
    ]);

    // ── Parse Shopify ─────────────────────────────────────────
    let shopifyDays = {};
    if (shopifyRes.status === 'fulfilled' && shopifyRes.value.ok) {
      const d = await shopifyRes.value.json();
      (d.daily || []).forEach(day => { shopifyDays[day.date] = day; });
      isLiveData = Object.keys(shopifyDays).length > 0;
    }

    // ── Parse Meta ────────────────────────────────────────────
    let metaDays = {};
    if (metaRes.status === 'fulfilled' && metaRes.value.ok) {
      const d = await metaRes.value.json();
      if (d.total) {
        livePlatforms.meta = d.total;
        updateAdCard('meta', d.total);
        // Update sidebar ROAS badge
        const roas = d.total.roas || 0;
        document.getElementById('meta-roas-badge').textContent = roas.toFixed(1) + '×';
        document.getElementById('meta-roas-badge').style.color =
          roas >= 3 ? 'var(--green)' : roas >= 2 ? 'var(--orange)' : 'var(--red)';
      }
      (d.daily || []).forEach(day => { metaDays[day.date] = day.spend || 0; });
    }

    // ── Merge into rows ───────────────────────────────────────
    if (isLiveData) {
      // Total meta spend across period, spread proportionally by day revenue
      const totalMetaSpend = livePlatforms.meta?.spend || 0;
      const totalShopifyRev = Object.values(shopifyDays).reduce((s,d) => s+d.revenue, 0);

      rows = Object.values(shopifyDays).map(day => {
        const rev    = day.revenue || 0;
        const orders = day.orders  || 0;
        // Spread meta spend proportionally by revenue share
        const dayShare = totalShopifyRev > 0 ? rev / totalShopifyRev : 0;
        const meta   = metaDays[day.date] !== undefined
          ? metaDays[day.date]
          : +(totalMetaSpend * dayShare).toFixed(2);
        const google = 0; // will be live once Google API approved
        const ms     = 0; // will be live once Microsoft connected
        const cogs   = +(orders * UNIT_COST).toFixed(2);
        const ship   = +(rev * SHIP_RATE).toFixed(2);
        return {
          date:    day.date,
          orders,
          revenue: rev,
          cogs,
          google,
          meta,
          ms,
          ship,
        };
      }).sort((a,b) => a.date.localeCompare(b.date));

      // Format dates nicely for display
      rows = rows.map(r => ({
        ...r,
        date: new Date(r.date).toLocaleDateString('en-AU', {month:'short', day:'2-digit'})
      }));

      toast('✓ Live data loaded — Shopify + Meta', 'ok');
    } else {
      toast('Using sample data — check proxy connection', 'err');
      loadSampleData();
    }

  } catch (err) {
    console.error('Sync error:', err);
    toast('Sync failed — using sample data', 'err');
    loadSampleData();
  }

  btn.textContent = '⟳ Refresh Data';
  btn.style.opacity = '1';
  btn.disabled = false;

  renderAll();
}

/* ── Update an ad platform card with live data ── */
function updateAdCard(platform, data) {
  if (!data) return;
  const pfx = platform === 'ms' ? 'ms' : platform;
  const spendEl  = document.getElementById(`${pfx}-spend-val`);
  const roasEl   = document.getElementById(`${pfx}-roas-val`);
  const revEl    = document.getElementById(`${pfx}-rev-val`);
  const cpaEl    = document.getElementById(`${pfx}-cpa-val`);
  const convEl   = document.getElementById(`${pfx}-conv-val`);
  const roasBar  = document.getElementById(`${pfx}-roas-bar`);

  if (spendEl) spendEl.textContent = '$' + (data.spend||0).toLocaleString(undefined,{maximumFractionDigits:0});
  if (revEl)   revEl.textContent   = '$' + (data.revenue||0).toLocaleString(undefined,{maximumFractionDigits:0});
  if (cpaEl)   cpaEl.textContent   = '$' + (data.cpa||0).toFixed(2);
  if (convEl)  convEl.textContent  = Math.round(data.conversions||0);
  if (roasEl) {
    const roas = data.roas || 0;
    roasEl.textContent  = roas.toFixed(1) + '×';
    roasEl.className    = 'am-v ' + (roas>=3?'good':roas>=2?'warn':'bad');
  }
  if (roasBar) {
    const pct = Math.min(100, ((data.roas||0)/5)*100);
    roasBar.style.width = pct + '%';
    roasBar.style.background = (data.roas||0)>=3 ? 'var(--green)' : 'var(--orange)';
  }
}

