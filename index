function exportCSV() {
  let csv = 'Date,Orders,Revenue,AOV,COGS,Google Ads,Meta Ads,Microsoft Ads,Shipping,Ad Spend,Net Profit,Margin\n';
  rows.forEach(r => {
    const c = calc(r);
    csv += `${r.date},${r.orders},${r.revenue},${c.aov},${r.cogs},${r.google},${r.meta},${r.ms},${r.ship},${c.ad},${c.profit},${c.margin}%\n`;
  });
  const a   = document.createElement('a');
  a.href    = URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download = 'foldifycase-profit-'+new Date().toISOString().slice(0,10)+'.csv';
  a.click();
  toast('CSV exported','ok');
}

