/* ══════════════════════════════════════════
   CALC + FORMAT
══════════════════════════════════════════ */
const calc = r => {
  const ad     = r.google + r.meta + r.ms;
  const total  = r.cogs + ad + r.ship;
  const profit = r.revenue - total;
  const margin = r.revenue > 0 ? ((profit/r.revenue)*100).toFixed(1) : '0.0';
  const aov    = r.orders  > 0 ? (r.revenue/r.orders).toFixed(2)    : '0.00';
  return { ad, total, profit, margin, aov };
};

const f$   = n  => '$' + Math.abs(Math.round(n)).toLocaleString();
const fPct = n  => parseFloat(n).toFixed(1) + '%';

function totals() {
  return rows.reduce((a,r) => {
    const c = calc(r);
    a.rev    += r.revenue;
    a.profit += c.profit;
    a.ad     += c.ad;
    a.cogs   += r.cogs;
    a.ship   += r.ship;
    a.orders += r.orders;
    return a;
  }, {rev:0, profit:0, ad:0, cogs:0, ship:0, orders:0});
}

/* ══════════════════════════════════════════
   RENDER ALL
══════════════════════════════════════════ */
function renderAll() {
  renderKPIs();
  renderSidebar();
  renderChart();
  renderBreakdown();
  renderTable();
}

function renderKPIs() {
  const t      = totals();
  const margin = t.rev > 0 ? ((t.profit/t.rev)*100).toFixed(1) : '0.0';
  const aov    = t.orders > 0 ? (t.rev/t.orders).toFixed(2) : '0.00';
  document.getElementById('kpi-profit').textContent = f$(t.profit);
  document.getElementById('kpi-profit').className   = 'kpi-val ' + (t.profit>=0?'green':'red');
  document.getElementById('kpi-rev').textContent    = f$(t.rev);
  document.getElementById('kpi-margin').textContent = fPct(margin);
  document.getElementById('kpi-aov').textContent    = f$(aov);
  document.getElementById('kpi-spend').textContent  = f$(t.ad);
  // Live indicator
  const badge = document.getElementById('liveBadge');
  if (badge) badge.textContent = isLiveData ? '🟢 LIVE' : '⚪ SAMPLE';
}

function renderSidebar() {
  const t      = totals();
  const margin = t.rev > 0 ? ((t.profit/t.rev)*100).toFixed(1) : '0.0';
  document.getElementById('sb-profit').textContent  = f$(t.profit);
  document.getElementById('sb-rev').textContent     = '$'+(t.rev/1000).toFixed(1)+'k';
  document.getElementById('sb-spend').textContent   = f$(t.ad);
  document.getElementById('sb-margin').textContent  = fPct(margin);
  document.getElementById('nb-entries').textContent = rows.length;
}

function renderChart() {
  const container = document.getElementById('barChart');
  container.innerHTML = '';
  if (!rows.length) return;
  const maxRev = Math.max(...rows.map(r => r.revenue));
  const H = 118;
  // baseline
  const bl = document.createElement('div');
  bl.style.cssText = 'position:absolute;bottom:22px;left:0;right:0;height:1px;background:rgba(28,27,24,0.08);pointer-events:none';
  container.appendChild(bl);
  rows.forEach(r => {
    const c    = calc(r);
    const revH = Math.round((r.revenue/maxRev)*H);
    const cstH = Math.round((c.total/maxRev)*H);
    const lbl  = r.date.includes(' ') ? r.date.split(' ')[1] : r.date.slice(-2);
    const div  = document.createElement('div');
    div.style.cssText = 'flex:1;display:flex;flex-direction:column;align-items:center;height:100%;cursor:pointer';
    div.title = `${r.date} | Revenue: ${f$(r.revenue)} | Costs: ${f$(c.total)} | Profit: ${f$(c.profit)} | Margin: ${c.margin}%`;
    div.innerHTML = `
      <div style="display:flex;gap:2px;align-items:flex-end;width:90%;height:${H}px">
        <div style="flex:1;display:flex;flex-direction:column;justify-content:flex-end">
          <div style="height:${revH}px;background:var(--gold);border-radius:3px 3px 0 0;opacity:.9"></div>
        </div>
        <div style="flex:1;display:flex;flex-direction:column;justify-content:flex-end">
          <div style="height:${cstH}px;background:${c.profit>0?'var(--ink-4)':'var(--red)'};border-radius:3px 3px 0 0;opacity:.55"></div>
        </div>
      </div>
      <div style="font-size:9px;color:var(--c3);font-family:var(--mono);margin-top:6px">${lbl}</div>`;
    container.appendChild(div);
  });
}

function renderBreakdown() {
  const t       = totals();
  const shopify = Math.round(t.rev * 0.005);
  const profit  = t.rev - t.cogs - t.ad - t.ship - shopify;
  const items   = [
    {name:'COGS',       amt:t.cogs,  pct:+(t.cogs/t.rev*100).toFixed(1),   color:'#7E6DB5', bg:'rgba(126,109,181,0.1)'},
    {name:'Ad Spend',   amt:t.ad,    pct:+(t.ad/t.rev*100).toFixed(1),     color:'#D95454', bg:'rgba(217,84,84,0.1)'},
    {name:'Shipping',   amt:t.ship,  pct:+(t.ship/t.rev*100).toFixed(1),   color:'#4A7FC1', bg:'rgba(74,127,193,0.1)'},
    {name:'Shopify Fee',amt:shopify, pct:+(shopify/t.rev*100).toFixed(1),  color:'#999',    bg:'rgba(0,0,0,0.05)'},
    {name:'Net Profit', amt:profit,  pct:+(profit/t.rev*100).toFixed(1),   color:'#5A9E72', bg:'rgba(90,158,114,0.1)'},
  ];
  function donut(pct, color, bg) {
    const r = 34, circ = 2*Math.PI*r;
    const filled = (Math.max(0,pct)/100)*circ;
    return `
      <circle cx="43" cy="43" r="${r}" fill="none" stroke="${bg}" stroke-width="9"/>
      <circle cx="43" cy="43" r="${r}" fill="none" stroke="${color}" stroke-width="9"
        stroke-dasharray="${filled.toFixed(2)} ${(circ-filled).toFixed(2)}" stroke-linecap="round"/>`;
  }
  document.getElementById('costBreakdown').innerHTML = items.map(i => `
    <div class="donut-item">
      <div class="donut-svg-wrap">
        <svg viewBox="0 0 86 86" xmlns="http://www.w3.org/2000/svg">${donut(i.pct,i.color,i.bg)}</svg>
        <div class="donut-center">
          <div class="donut-pct" style="color:${i.color}">${i.pct}%</div>
        </div>
      </div>
      <div class="donut-name">${i.name}</div>
      <div class="donut-amt">${f$(i.amt)}</div>
    </div>`).join('');
}

function renderTable() {
  const tb = document.getElementById('tableBody');
  tb.innerHTML = '';
  rows.forEach(r => {
    const c       = calc(r);
    const mgCls   = parseFloat(c.margin)>=20?'mgn-g':parseFloat(c.margin)>=10?'mgn-w':'mgn-r';
    const chipCls = c.profit>=0?'chip-g':'chip-r';
    const sign    = c.profit<0?'−':'';
    const tr      = document.createElement('tr');
    tr.innerHTML  = `
      <td class="mono" style="color:var(--c2);font-size:12px">${r.date}</td>
      <td class="r mono">${f$(r.revenue)}</td>
      <td class="r mono" style="color:var(--c3)">${r.orders}</td>
      <td class="r mono" style="color:var(--c2)">${f$(c.aov)}</td>
      <td class="r mono" style="color:var(--purple)">${f$(r.cogs)}</td>
      <td class="r mono" style="color:var(--red)">${f$(c.ad)}</td>
      <td class="r mono" style="color:var(--blue)">${f$(r.ship)}</td>
      <td class="r"><span class="chip ${chipCls}">${sign}${f$(c.profit)}</span></td>
      <td class="r"><span class="mgn-badge ${mgCls}">${c.margin}%</span></td>`;
    tb.appendChild(tr);
  });
  document.getElementById('tblCount').textContent = rows.length + (isLiveData?' live entries':' sample entries');
}

/* ══════════════════════════════════════════
   MANUAL ENTRY
══════════════════════════════════════════ */
function addEntry() {
  const rev    = parseFloat(document.getElementById('eRev').value)||0;
  const orders = parseInt(document.getElementById('eOrd').value)||0;
  const unit   = parseFloat(document.getElementById('eCOGS').value)||0;
  const google = parseFloat(document.getElementById('eGoogle').value)||0;
  const meta   = parseFloat(document.getElementById('eMeta').value)||0;
  const ms     = parseFloat(document.getElementById('eMs').value)||0;
  const ship   = parseFloat(document.getElementById('eShip').value)||0;
  if (!rev) { toast('Please enter a revenue figure','err'); return; }
  const d     = new Date(document.getElementById('eDate').value);
  const label = d.toLocaleDateString('en-AU',{month:'short',day:'2-digit'});
  rows.unshift({date:label, orders, revenue:rev, cogs:unit*orders, google, meta, ms, ship});
  clearForm();
  renderAll();
  toast(`Entry for ${label} added`,'ok');
}

function clearForm() {
  ['eRev','eOrd','eCOGS','eGoogle','eMeta','eMs','eShip'].forEach(id => document.getElementById(id).value='');
}

