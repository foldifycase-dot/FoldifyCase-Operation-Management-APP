<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FoldifyCase — Profit Tracking</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════════
   TOKENS — exact match to Warehouse Hub
══════════════════════════════════════════ */
:root {
  --ink:         #1C1B18;
  --ink-2:       #252420;
  --ink-3:       #2E2D28;
  --ink-4:       #3A3930;
  --cream:       #F0EDE3;
  --cream-2:     #E8E4D8;
  --cream-3:     #DDD8C8;
  --gold:        #C8A96E;
  --gold-2:      #B8944E;
  --gold-dim:    rgba(200,169,110,0.15);
  --gold-bg:     rgba(200,169,110,0.08);
  --green:       #5A9E72;
  --green-dim:   rgba(90,158,114,0.14);
  --red:         #D95454;
  --red-dim:     rgba(217,84,84,0.12);
  --orange:      #D4874A;
  --orange-dim:  rgba(212,135,74,0.13);
  --blue:        #4A7FC1;
  --blue-dim:    rgba(74,127,193,0.12);
  --purple:      #7E6DB5;
  --purple-dim:  rgba(126,109,181,0.12);
  /* text on dark */
  --t1: #F0EDE3;
  --t2: rgba(240,237,227,0.62);
  --t3: rgba(240,237,227,0.36);
  --t4: rgba(240,237,227,0.18);
  /* text on cream */
  --c1: #1C1B18;
  --c2: rgba(28,27,24,0.58);
  --c3: rgba(28,27,24,0.36);
  /* layout */
  --topbar-h:  52px;
  --sidebar-w: 282px;
  --r:   8px;
  --r-s: 5px;
  /* fonts */
  --dis:  'Syne', sans-serif;
  --sans: 'DM Sans', sans-serif;
  --mono: 'DM Mono', monospace;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html, body { height:100%; }
body { font-family:var(--sans); font-size:13px; background:var(--ink); color:var(--t1); overflow-x:hidden; }

/* ════════════════════════  TOPBAR  */
.topbar {
  position:fixed; top:0; left:0; right:0;
  height:var(--topbar-h);
  background:var(--ink);
  border-bottom:1px solid rgba(255,255,255,0.07);
  display:flex; align-items:center;
  z-index:200;
}

.topbar-logo {
  display:flex; align-items:center; gap:10px;
  padding:0 20px;
  height:100%;
}
.logo-icon-wrap {
  width:32px; height:32px; flex-shrink:0;
  background:#000;
  border-radius:7px;
  display:flex; align-items:center; justify-content:center;
  overflow:hidden;
}
.logo-icon-wrap img { width:26px; height:26px; object-fit:contain; }
.logo-wordmark {
  font-family:var(--dis); font-weight:800;
  font-size:15px; letter-spacing:0.1em;
  color:var(--t1); text-transform:uppercase;
}

/* ════════════════════════  LAYOUT  */
.layout {
  display:flex;
  margin-top:var(--topbar-h);
  min-height:calc(100vh - var(--topbar-h));
}

.sdot { width:6px; height:6px; border-radius:50%; background:var(--green); animation:blink 2s infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.35} }

/* ════════════════════════  MAIN CONTROLS BAR  */
.main-controls {
  display:flex; align-items:center; gap:8px;
  padding:16px 28px 0;
  flex-wrap:wrap;
}
.rp {
  padding:6px 14px; background:#fff;
  border:1px solid var(--cream-3); color:var(--c3);
  border-radius:var(--r-s); font-family:var(--mono);
  font-size:11px; cursor:pointer; transition:all 0.14s; letter-spacing:0.04em;
}
.rp:hover { color:var(--c2); border-color:rgba(28,27,24,0.25); }
.rp.active { background:var(--ink); border-color:var(--ink); color:var(--t1); }
.mkt {
  padding:6px 11px; background:#fff;
  border:1px solid var(--cream-3);
  border-radius:var(--r-s); font-family:var(--mono);
  font-size:11px; cursor:pointer; transition:all 0.14s;
  letter-spacing:0.05em; color:var(--c3);
}
.mkt:hover { border-color:rgba(28,27,24,0.25); color:var(--c2); }
.mkt.active { background:var(--gold); border-color:var(--gold); color:var(--ink); font-weight:600; }
.controls-divider { width:1px; height:22px; background:var(--cream-3); flex-shrink:0; }
.ctrl-right { margin-left:auto; display:flex; gap:8px; }

/* ════════════════════════  DONUT CHART  */
.donut-grid {
  display:grid; grid-template-columns:repeat(4,1fr);
  gap:14px; padding:16px 18px;
}
.donut-item { display:flex; flex-direction:column; align-items:center; gap:8px; }
.donut-svg-wrap { position:relative; width:86px; height:86px; flex-shrink:0; }
.donut-svg-wrap svg { width:86px; height:86px; transform:rotate(-90deg); }
.donut-center {
  position:absolute; inset:0;
  display:flex; flex-direction:column;
  align-items:center; justify-content:center;
}
.donut-pct { font-family:var(--dis); font-weight:700; font-size:14px; line-height:1; color:var(--c1); }
.donut-name { font-size:10px; color:var(--c3); font-family:var(--mono); text-align:center; line-height:1.3; margin-top:2px; }
.donut-amt { font-family:var(--mono); font-size:12px; font-weight:500; color:var(--c2); }

/* ════════════════════════  SIDEBAR  */
.sidebar {
  width:var(--sidebar-w); flex-shrink:0;
  background:var(--ink-2);
  border-right:1px solid rgba(255,255,255,0.06);
  position:sticky; top:var(--topbar-h);
  height:calc(100vh - var(--topbar-h));
  overflow-y:auto;
  display:flex; flex-direction:column;
}

.sb-label {
  font-family:var(--dis); font-size:9px;
  font-weight:600; letter-spacing:0.18em; text-transform:uppercase;
  color:var(--gold); padding:16px 18px 8px;
}

/* 2x2 stat cards — matches Hub exactly */
.sb-stats {
  display:grid; grid-template-columns:1fr 1fr;
  gap:8px; padding:0 14px 14px;
}
.sb-stat {
  background:var(--ink-3);
  border:1px solid rgba(255,255,255,0.06);
  border-radius:var(--r); padding:12px 14px;
  cursor:default; transition:border-color 0.15s;
}
.sb-stat:hover { border-color:rgba(200,169,110,0.3); }
.sb-stat-val {
  font-family:var(--dis); font-weight:700;
  font-size:22px; line-height:1; margin-bottom:4px;
  letter-spacing:-0.01em;
}
.sv-gold   { color:var(--gold); }
.sv-green  { color:var(--green); }
.sv-red    { color:var(--red); }
.sv-cream  { color:var(--t1); }
.sb-stat-label { font-size:10px; color:var(--t3); }

/* Auto-sync toggle */
.sb-toggle-row {
  margin:0 14px 14px;
  background:rgba(90,158,114,0.09);
  border:1px solid rgba(90,158,114,0.22);
  border-radius:var(--r);
  padding:10px 13px;
  display:flex; align-items:center; justify-content:space-between;
}
.sb-toggle-label {
  display:flex; align-items:center; gap:7px;
  font-size:12px; color:var(--green); font-weight:500;
}
.toggle { position:relative; width:38px; height:22px; flex-shrink:0; }
.toggle input { opacity:0; width:0; height:0; }
.toggle-track {
  position:absolute; inset:0;
  background:rgba(255,255,255,0.1);
  border-radius:22px; cursor:pointer;
  transition:background 0.25s;
}
.toggle input:checked ~ .toggle-track { background:var(--green); }
.toggle-thumb {
  position:absolute; width:16px; height:16px;
  background:#fff; border-radius:50%;
  top:3px; left:3px;
  transition:transform 0.25s; pointer-events:none;
}
.toggle input:checked ~ .toggle-thumb { transform:translateX(16px); }

.sb-div { height:1px; background:rgba(255,255,255,0.06); margin:4px 0 12px; }

/* Nav items */
.sb-nav-item {
  display:flex; align-items:center; justify-content:space-between;
  padding:9px 18px; cursor:pointer;
  border-left:2px solid transparent;
  transition:all 0.12s;
}
.sb-nav-item:hover { background:rgba(255,255,255,0.04); }
.sb-nav-item.active {
  background:var(--gold-dim);
  border-left-color:var(--gold);
}
.sb-nav-left {
  display:flex; align-items:center; gap:9px;
  font-size:12px; font-weight:500; color:var(--t3);
}
.sb-nav-item.active .sb-nav-left { color:var(--gold); }
.sb-nav-item:not(.active):hover .sb-nav-left { color:var(--t2); }
.sb-nav-icon { font-size:11px; width:15px; text-align:center; }
.sb-nav-badge {
  font-size:9px; font-family:var(--mono);
  padding:2px 7px; border-radius:20px;
  background:rgba(255,255,255,0.09); color:var(--t3);
}
.sb-nav-item.active .sb-nav-badge {
  background:var(--gold); color:var(--ink);
}

/* Shopify connection block */
.sb-shopify {
  margin:auto 14px 14px;
  background:rgba(255,255,255,0.03);
  border:1px solid rgba(255,255,255,0.07);
  border-radius:var(--r); padding:13px;
}
.sb-shopify-title {
  font-size:9px; letter-spacing:0.16em;
  text-transform:uppercase; color:var(--gold);
  font-family:var(--mono); margin-bottom:9px;
  display:flex; align-items:center; gap:6px;
}
.sb-shopify input {
  width:100%; padding:7px 10px;
  background:rgba(0,0,0,0.25);
  border:1px solid rgba(255,255,255,0.09);
  border-radius:var(--r-s); color:var(--t1);
  font-family:var(--mono); font-size:11px;
  outline:none; transition:border-color 0.2s; margin-bottom:8px;
}
.sb-shopify input:focus { border-color:var(--gold); }
.sb-shopify input::placeholder { color:var(--t4); }
.btn-conn {
  width:100%; padding:7px; background:var(--gold);
  color:var(--ink); border:none; border-radius:var(--r-s);
  font-family:var(--dis); font-weight:700; font-size:11px;
  letter-spacing:0.08em; cursor:pointer; transition:all 0.2s;
}
.btn-conn:hover { background:var(--gold-2); color:#fff; }
.conn-live {
  font-size:10px; color:var(--green);
  margin-top:7px; display:flex; align-items:center; gap:5px;
  font-family:var(--mono);
}

/* ════════════════════════  MAIN  */
.main {
  flex:1; background:var(--cream);
  min-height:calc(100vh - var(--topbar-h));
  overflow-y:auto;
}

/* Page header */
.page-hd {
  padding:26px 28px 0;
  display:flex; align-items:flex-start;
  justify-content:space-between; gap:20px;
}
.page-title {
  font-family:var(--dis); font-weight:800;
  font-size:27px; letter-spacing:-0.01em;
  line-height:1; color:var(--c1);
}
.page-title .gold { color:var(--gold-2); }
.page-sub {
  font-size:12px; color:var(--c3);
  margin-top:6px; line-height:1.5; max-width:500px;
}
.page-hd-btns { display:flex; gap:8px; flex-shrink:0; }
.btn-out {
  padding:8px 16px; background:transparent;
  border:1.5px solid rgba(28,27,24,0.18);
  border-radius:var(--r-s); font-family:var(--sans);
  font-size:12px; font-weight:500; color:var(--c1);
  cursor:pointer; transition:all 0.15s;
  display:flex; align-items:center; gap:5px;
}
.btn-out:hover { background:var(--ink); color:var(--t1); border-color:var(--ink); }
.btn-ink {
  padding:8px 18px; background:var(--ink);
  border:none; border-radius:var(--r-s);
  font-family:var(--dis); font-weight:700;
  font-size:12px; letter-spacing:0.05em;
  color:var(--t1); cursor:pointer; transition:all 0.2s;
}
.btn-ink:hover { background:var(--ink-4); }
.btn-ink.syncing { opacity:0.65; pointer-events:none; }

/* ── Section label ── */
.sec {
  font-family:var(--mono); font-size:9px;
  letter-spacing:0.2em; text-transform:uppercase;
  color:var(--c3); display:flex; align-items:center; gap:10px;
  margin-bottom:12px;
}
.sec::after { content:''; flex:1; height:1px; background:rgba(28,27,24,0.1); }

/* Padding wrapper */
.pad { padding:22px 28px; }
.pad-t { padding-top:22px; }

/* ════════════════════════  KPI STRIP  */
/* 5 equal KPI cards in a row */
.kpi-strip {
  display:grid; grid-template-columns:repeat(5,1fr);
  gap:10px; margin-bottom:0;
}
.kpi {
  background:#fff;
  border:1px solid rgba(28,27,24,0.1);
  border-radius:var(--r); padding:16px 16px 14px;
  position:relative; overflow:hidden;
  transition:border-color 0.15s; cursor:default;
}
.kpi:hover { border-color:rgba(200,169,110,0.5); }
.kpi::before {
  content:''; position:absolute;
  top:0; left:0; right:0; height:3px;
}
.kpi.k-profit::before  { background:var(--green); }
.kpi.k-revenue::before { background:var(--gold); }
.kpi.k-spend::before   { background:var(--red); }
.kpi.k-margin::before  { background:var(--blue); }
.kpi.k-aov::before     { background:var(--purple); }
.kpi.k-roas::before    { background:var(--orange); }

.kpi-label {
  font-family:var(--mono); font-size:8.5px;
  letter-spacing:0.18em; text-transform:uppercase;
  color:var(--c3); margin-bottom:9px;
  display:flex; align-items:center; gap:6px;
}
.kpi-dot { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
.kpi-val {
  font-family:var(--dis); font-weight:800;
  font-size:26px; line-height:1;
  letter-spacing:-0.02em; color:var(--c1);
  margin-bottom:6px;
}
.kpi-val.green  { color:var(--green); }
.kpi-val.gold   { color:var(--gold-2); }
.kpi-val.red    { color:var(--red); }
.kpi-val.blue   { color:var(--blue); }
.kpi-val.purple { color:var(--purple); }
.kpi-val.orange { color:var(--orange); }

.kpi-change {
  font-family:var(--mono); font-size:11px;
  display:flex; align-items:center; gap:3px;
}
.kpi-change.up   { color:var(--green); }
.kpi-change.down { color:var(--red); }
.kpi-change.neu  { color:var(--c3); }
.kpi-sub { font-size:10px; color:var(--c3); margin-top:1px; }

/* ════════════════════════  TWO-COLUMN GRID  */
.two-col { display:grid; grid-template-columns:1.55fr 1fr; gap:12px; }
.three-col { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; }

/* ── Card shell ── */
.card {
  background:#fff;
  border:1px solid rgba(28,27,24,0.1);
  border-radius:var(--r); overflow:hidden;
}
.card-hd {
  padding:13px 16px;
  border-bottom:1px solid rgba(28,27,24,0.07);
  background:var(--cream-2);
  display:flex; align-items:center; justify-content:space-between;
}
.card-title {
  font-family:var(--dis); font-weight:700;
  font-size:12px; color:var(--c1); letter-spacing:0.01em;
}
.badge {
  font-family:var(--mono); font-size:9px;
  padding:2px 8px; border-radius:20px; border:1px solid;
}
.badge.gold   { border-color:rgba(200,169,110,0.4); color:var(--gold-2); background:var(--gold-bg); }
.badge.green  { border-color:rgba(90,158,114,0.35); color:var(--green); background:var(--green-dim); }
.badge.red    { border-color:rgba(217,84,84,0.3);   color:var(--red);   background:var(--red-dim); }
.badge.blue   { border-color:rgba(74,127,193,0.3);  color:var(--blue);  background:var(--blue-dim); }
.badge.orange { border-color:rgba(212,135,74,0.3);  color:var(--orange);background:var(--orange-dim); }

.card-body { padding:14px 16px; }

/* ════════════════════════  MINI SPARKLINE  */
.sparkline-wrap { position:relative; height:70px; margin-bottom:10px; }
svg.spark { width:100%; height:100%; }

/* ════════════════════════  COST BREAKDOWN  */
.cost-rows { }
.cost-row {
  display:flex; align-items:center;
  justify-content:space-between;
  padding:8px 0;
  border-bottom:1px solid rgba(28,27,24,0.06);
}
.cost-row:last-child { border-bottom:none; }
.cost-left { }
.cost-name { font-size:12px; color:var(--c1); margin-bottom:2px; }
.cost-pct  { font-family:var(--mono); font-size:10px; color:var(--c3); }
.cost-right { display:flex; align-items:center; gap:8px; }
.cost-bar-track {
  width:72px; height:4px;
  background:var(--cream-3);
  border-radius:2px; overflow:hidden;
}
.cost-bar-fill { height:100%; border-radius:2px; }
.cost-amount { font-family:var(--mono); font-size:12px; font-weight:500; min-width:58px; text-align:right; }

/* ════════════════════════  AD PLATFORM CARDS  */
.ad-card {
  background:#fff;
  border:1px solid rgba(28,27,24,0.1);
  border-radius:var(--r); padding:16px;
  position:relative; overflow:hidden;
  transition:border-color 0.15s;
}
.ad-card:hover { border-color:rgba(200,169,110,0.4); }
.ad-card::before {
  content:''; position:absolute;
  top:0; left:0; right:0; height:3px;
}
.ad-card.google::before { background:linear-gradient(90deg,#4285F4,#34A853,#FBBC05,#EA4335); }
.ad-card.meta::before   { background:linear-gradient(90deg,#1877F2,#E1306C); }
.ad-card.ms::before     { background:linear-gradient(90deg,#00A4EF,#107C10,#FFB900); }

.ad-pname {
  font-family:var(--mono); font-size:9px;
  letter-spacing:0.16em; text-transform:uppercase;
  color:var(--c3); margin-bottom:10px;
  display:flex; align-items:center; gap:6px;
}
.ad-pip { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
.google .ad-pip { background:#4285F4; }
.meta   .ad-pip { background:#1877F2; }
.ms     .ad-pip { background:#00A4EF; }

.ad-spend {
  font-family:var(--dis); font-weight:800;
  font-size:22px; color:var(--c1); letter-spacing:-0.02em;
  line-height:1; margin-bottom:2px;
}
.ad-spend-sub { font-size:10px; color:var(--c3); margin-bottom:12px; }

.ad-mets {
  display:grid; grid-template-columns:1fr 1fr;
  gap:8px; padding-top:10px;
  border-top:1px solid rgba(28,27,24,0.07);
}
.am-l {
  font-family:var(--mono); font-size:8.5px;
  letter-spacing:0.1em; text-transform:uppercase;
  color:var(--c3); margin-bottom:2px;
}
.am-v { font-family:var(--mono); font-size:13px; font-weight:500; color:var(--c2); }
.am-v.good { color:var(--green); }
.am-v.warn { color:var(--orange); }
.am-v.bad  { color:var(--red); }

/* ROAS gauge mini */
.roas-bar-track {
  height:3px; background:var(--cream-3);
  border-radius:2px; overflow:hidden; margin-top:4px;
}
.roas-bar-fill { height:100%; border-radius:2px; }

/* ════════════════════════  DAILY TABLE  */
.tbl-wrap { overflow-x:auto; }
table { width:100%; border-collapse:collapse; }
thead tr { background:var(--cream-2); }
th {
  padding:9px 14px; text-align:left;
  font-family:var(--mono); font-size:8.5px;
  letter-spacing:0.18em; text-transform:uppercase;
  color:var(--c3); font-weight:400;
  border-bottom:1px solid rgba(28,27,24,0.08);
  white-space:nowrap;
}
th.r { text-align:right; }
td {
  padding:11px 14px; border-bottom:1px solid rgba(28,27,24,0.06);
  vertical-align:middle;
}
td.r { text-align:right; }
td.mono { font-family:var(--mono); font-size:12px; }
tr:last-child td { border-bottom:none; }
tbody tr:hover td { background:rgba(200,169,110,0.04); }

.chip {
  display:inline-flex; align-items:center;
  padding:3px 9px; border-radius:20px;
  font-family:var(--mono); font-size:11px; font-weight:500;
}
.chip-g { background:var(--green-dim); color:var(--green); }
.chip-r { background:var(--red-dim);   color:var(--red); }
.chip-o { background:var(--orange-dim);color:var(--orange); }

.mgn-badge {
  display:inline-block; font-family:var(--mono);
  font-size:9px; padding:2px 6px; border-radius:4px;
}
.mgn-g { background:rgba(90,158,114,0.08);  color:var(--green); }
.mgn-w { background:rgba(212,135,74,0.1);   color:var(--orange); }
.mgn-r { background:rgba(217,84,84,0.08);   color:var(--red); }

/* ════════════════════════  LOG ENTRY FORM  */
.log-form {
  background:var(--ink);
  border-radius:var(--r); padding:20px 22px;
}
.lf-title { font-family:var(--dis); font-weight:700; font-size:14px; color:var(--t1); margin-bottom:2px; }
.lf-sub   { font-size:11px; color:var(--t3); margin-bottom:16px; }
.lf-grid  { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; }
.lf-field label {
  display:block; font-family:var(--mono); font-size:8.5px;
  letter-spacing:0.16em; text-transform:uppercase;
  color:var(--t3); margin-bottom:5px;
}
.lf-field input {
  width:100%; padding:8px 11px;
  background:rgba(255,255,255,0.06);
  border:1px solid rgba(255,255,255,0.09);
  border-radius:var(--r-s); color:var(--t1);
  font-family:var(--mono); font-size:12px;
